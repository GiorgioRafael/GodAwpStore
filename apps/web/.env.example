# Supabase public configuration (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Supabase server-only key. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# Comma-separated Discord snowflakes allowed to administer the platform.
ADMIN_DISCORD_IDS=123456789012345678

# Generate independent 32-byte values and encode them as base64.
INVENTORY_ENCRYPTION_KEY=replace_with_32_random_bytes_in_base64
INVENTORY_FINGERPRINT_KEY=replace_with_an_independent_random_base64_key

# Used to build the OAuth callback URL locally. Change only when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Discord bot (server-only). The public key verifies HTTP Interactions.
DISCORD_APPLICATION_ID=123456789012345678
DISCORD_PUBLIC_KEY=replace_with_the_64_character_hex_public_key
DISCORD_BOT_TOKEN=replace_with_the_discord_bot_token

# LivePix OAuth client credentials (server-only). The app uses its own account,
# so this integration uses client_credentials and does not require an OAuth callback.
LIVEPIX_CLIENT_ID=replace_with_the_livepix_client_id
LIVEPIX_CLIENT_SECRET=replace_with_the_livepix_client_secret

# Optional: register slash commands in one guild for immediate development
# instead of globally (global commands can take time to propagate).
DISCORD_GUILD_ID=
