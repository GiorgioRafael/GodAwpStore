{
  "name": "@godawp/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "discord:commands": "node --env-file-if-exists=.env.local scripts/register-discord-commands.mjs",
    "discord:tickets:sync": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/sync-open-ticket-controls.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.34.0",
    "@chat-adapter/state-memory": "^4.34.0",
    "@godawp/domain": "*",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "chat": "^4.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord-interactions": "^4.4.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.0.7"
  }
}
