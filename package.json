{
  "name": "god-awp-store",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @godawp/web",
    "build": "npm run build --workspace @godawp/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "sharp": "0.35.3"
  },
  "allowScripts": {
    "sharp": true,
    "unrs-resolver": true
  },
  "overrides": {
    "sharp": "$sharp",
    "next@16.2.10": {
      "postcss": "8.5.19",
      "sharp": "$sharp"
    }
  }
}
